DATABASE_URL=sqlite:///./financas.db

# CORS - origens do navegador autorizadas a chamar esta API. Opcional: ja
# tem esse valor como default no codigo (app/core/config.py), entao o
# frontend em localhost:5173 funciona mesmo sem declarar isso aqui. So
# precisa descomentar/editar se o frontend rodar em outra porta/host.
# CORS_ORIGINS=["http://localhost:5173"]

# Autenticacao / JWT
# OBRIGATORIO - a aplicacao nao sobe sem isso definido. Gere a sua propria
# chave, NUNCA reaproveite o exemplo abaixo (ele so ilustra o formato).
# Sugestao para gerar uma chave forte: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=troque-por-uma-chave-gerada-com-secrets-token-urlsafe-32
JWT_ALGORITHM=HS256
JWT_KEY_ID=v1
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Logging
LOG_LEVEL=INFO
